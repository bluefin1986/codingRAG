{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "codingRAG API",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "api.app:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8060",
                "--reload"
            ],
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env.debug",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "codingRAG ingest worker",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/library_import_worker.py",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env.debug",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env.debug",
            "console": "integratedTerminal"
        }
    ],
    "compounds": [
        {
            "name": "codingRAG API + ingest worker",
            "configurations": [
                "codingRAG API",
                "codingRAG ingest worker"
            ],
            "stopAll": true
        }
    ]
}
