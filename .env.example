# codingRAG Docker Compose local configuration
# Copy to .env and adjust per machine.

COMPOSE_PROJECT_NAME=codingrag

# Main application
CODINGRAG_CONTAINER_NAME=codingrag-app
CODINGRAG_HTTP_PORT=8060

CODING_RAG_KEYWORD_BACKEND=opensearch

# OpenSearch / Elasticsearch keyword search backend
# Example:
#   http://localhost:9200
#   http://opensearch:9200
CODING_RAG_ES_URL=http://opensearch:9200

# Optional API key for secured Elasticsearch/OpenSearch clusters.
# Leave empty when security plugin is disabled.
CODING_RAG_ES_API_KEY=

# Per-domain keyword index names
CODING_RAG_ES_INDEX_HARMONYOS=codingrag_harmonyos_docs
CODING_RAG_ES_INDEX_IOS=codingrag_ios_docs

# OpenSearch container
OPENSEARCH_IMAGE=codingrag-opensearch-ik:2.19.1
OPENSEARCH_CONTAINER_NAME=codingrag-opensearch
OPENSEARCH_HTTP_PORT=9200
OPENSEARCH_PERF_PORT=9600

# OpenSearch JVM memory settings
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m

# Machine-specific storage path for OpenSearch persistent data.
# Local Mac example:
OPENSEARCH_DATA_DIR=/Volumes/BDisk/bizData/opensearch
# Portable fallback example:
# OPENSEARCH_DATA_DIR=./data/opensearch

# Optional preload domains, comma separated
CODING_RAG_PRELOAD_DOMAINS=

# Qdrant API key used by both app and qdrant
# Generate with: uuidgen
QDRANT_API_KEY=QDRANT_API_KEY

# Qdrant
QDRANT_CONTAINER_NAME=codingrag-qdrant
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# Machine-specific storage path for Qdrant persistent data.
# Local Mac example:
QDRANT_STORAGE_DIR=/Volumes/BDisk/bizData/qdrant
# Portable fallback example:
# QDRANT_STORAGE_DIR=./data/qdrant

# PostgreSQL document registry
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_CONTAINER_NAME=codingrag-postgres
POSTGRES_PORT=5432
POSTGRES_DB=codingrag
POSTGRES_USER=codingrag
POSTGRES_PASSWORD=codingrag
POSTGRES_DATA_DIR=/Volumes/BDisk/bizData/codingrag/postgres
CODING_RAG_DATABASE_URL=postgresql://codingrag:codingrag@postgres:5432/codingrag

# Original document object storage
# Supported values: local / seaweedfs / minio / s3
CODING_RAG_STORAGE_BACKEND=seaweedfs

# SeaweedFS (filer HTTP API for uploads/reads; S3-compatible API exposed for migration/tooling)
SEAWEEDFS_IMAGE=chrislusf/seaweedfs:latest
SEAWEEDFS_MASTER_CONTAINER_NAME=codingrag-seaweedfs-master
SEAWEEDFS_VOLUME_CONTAINER_NAME=codingrag-seaweedfs-volume
SEAWEEDFS_FILER_CONTAINER_NAME=codingrag-seaweedfs-filer
SEAWEEDFS_MASTER_PORT=9333
SEAWEEDFS_VOLUME_PORT=8080
SEAWEEDFS_FILER_PORT=8888
SEAWEEDFS_S3_PORT=8333
SEAWEEDFS_VOLUME_MAX=7
SEAWEEDFS_MASTER_DATA_DIR=/Volumes/BDisk/bizData/codingrag/seaweedfs/master
SEAWEEDFS_VOLUME_DATA_DIR=/Volumes/BDisk/bizData/codingrag/seaweedfs/volume
SEAWEEDFS_FILER_DATA_DIR=/Volumes/BDisk/bizData/codingrag/seaweedfs/filer
CODING_RAG_SEAWEEDFS_FILER_URL=http://seaweedfs-filer:8888
CODING_RAG_SEAWEEDFS_PUBLIC_BASE_URL=http://seaweedfs-filer:8888
CODING_RAG_SEAWEEDFS_S3_ENDPOINT=http://seaweedfs-filer:8333
CODING_RAG_SEAWEEDFS_BUCKET=codingrag-originals
CODING_RAG_SEAWEEDFS_KEY_PREFIX=libraries
CODING_RAG_IMPORT_BATCH_SIZE=100
